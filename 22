    // Задание 4: Найти число с минимальным количеством различных цифр
    public static int findNumberWithMinUniqueDigits(int[] array) {
        int minUniqueCount = Integer.MAX_VALUE;
        int result = array[0];

        for (int num : array) {
            int uniqueCount = countUniqueDigits(num);
            if (uniqueCount < minUniqueCount) {
                minUniqueCount = uniqueCount;
                result = num;
            }
        }

        return result;
    }

    // Подсчет количества различных цифр в числе
    private static int countUniqueDigits(int number) {
        number = Math.abs(number);
        if (number == 0) return 1;

        boolean[] digits = new boolean[10];
        while (number > 0) {
            digits[number % 10] = true;
            number /= 10;
        }

        int count = 0;
        for (boolean digit : digits) {
            if (digit) count++;
        }
        return count;
    }

    // Задание 5: Подсчет чисел с четными цифрами и с равным числом четных и нечетных
    public static int[] countEvenDigitsNumbers(int[] array) {
        int evenDigitsOnly = 0; // Только четные цифры
        int equalEvenOdd = 0;    // Равное количество четных и нечетных

        for (int num : array) {
            int[] evenOddCount = countEvenAndOddDigits(num);
            int even = evenOddCount[0];
            int odd = evenOddCount[1];

            // Проверка: все цифры четные
            if (odd == 0) {
                evenDigitsOnly++;
            }

                    //' Проверка: равное количество четных и нечетных
            if (even == odd) {
                equalEvenOdd++;
            }
        }

        return new int[]{evenDigitsOnly, equalEvenOdd};
    }

    // Подсчет четных и нечетных цифр в числе
    private static int[] countEvenAndOddDigits(int number) {
        number = Math.abs(number);
        if (number == 0) return new int[]{1, 0}; // 0 - четная цифра

        int even = 0, odd = 0;
        while (number > 0) {
            int digit = number % 10;
            if (digit % 2 == 0) {
                even++;
            } else {
                odd++;
            }
            number /= 10;
        }
        return new int[]{even, odd};
    }

    // Задание 6: Найти первое число с цифрами в строгом порядке возрастания
    public static int findFirstIncreasingDigitsNumber(int[] array) {
        for (int num : array) {
            if (hasIncreasingDigits(num)) {
                return num;
            }
        }
        return Integer.MIN_VALUE; // Если таких чисел нет
    }

    // Проверка, идут ли цифры в строгом порядке возрастания
    private static boolean hasIncreasingDigits(int number) {
        number = Math.abs(number);
        if (number < 10) return true; // Однозначное число считается возрастающим

        int prevDigit = number % 10;
        number /= 10;

        while (number > 0) {
            int currentDigit = number % 10;
            if (currentDigit >= prevDigit) {
                return false; // Не строго возрастает (должно быть currentDigit < prevDigit)
            }
            prevDigit = currentDigit;
            number /= 10;
        }
        return true;
    }

    // Задание 7: Найти первое число только из различных цифр
    public static int findFirstUniqueDigitsNumber(int[] array) {
        for (int num : array) {
            if (hasAllUniqueDigits(num)) {
                return num;
            }
        }
        return Integer.MIN_VALUE; // Если таких чисел нет
    }

    // Проверка, все ли цифры в числе различны
    private static boolean hasAllUniqueDigits(int number) {
        number = Math.abs(number);
        if (number < 10) return true; // Однозначное число всегда с различными цифрами

        boolean[] seen = new boolean[10];
        while (number > 0) {
            int digit = number % 10;
            if (seen[digit]) {
                return false; // Цифра уже встречалась
            }
            seen[digit] = true;
            number /= 10;
        }
        return true;
    }

