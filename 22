    public static List<Integer> sostav(int ii) {
        List<Integer> masiv = new ArrayList<>();
        ii = Math.abs(ii);

        if (ii == 0) {
            masiv.add(0);
            return masiv;
        }

        while (ii > 0) {
            masiv.add(0, ii % 10);
            ii /= 10;
        }
        return masiv;
    }

    public static int[] summpopolam(int[] masa, int cala){
        int[] sered = new int[cala];
        int sum = 0;
        for (int i = 0; i < cala; i++){
            sum += masa[i];
        }
        int index = 0;
        for (int i = 0; i < cala; i++){
            if (masa[i] > sum / cala) {
                sered[index++] = masa[i];
            }
        }
        // Обрезаем массив до фактического размера
        return Arrays.copyOf(sered, index);
    }

    public static int[] colichestvo(int[] masa, int cala) {
        int[] res = new int[cala];
        for (int j = 0; j < cala; j++) {

            int number = 0;
            int temp = masa[j];
            if (temp == 0){
                number = 1;
            } else {
                temp = Math.abs(temp);
                while (temp != 0){
                    temp /= 10;
                    number++;
                }
            }
            res[j] = number;
        }
        return res;
    }

    public static int[] sort(int[] masa, int cala) {
        int[] res = masa.clone();
        for (int j = 1; j < cala; j++) {
            for (int i = 0; i < cala - 1; i++) {
                if (res[i] > res[i + 1]) {
                    int temp = res[i];
                    res[i] = res[i + 1];
                    res[i + 1] = temp;
                }
            }
        }
        return res;
    }
